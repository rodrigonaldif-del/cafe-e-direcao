{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    { "source": "/(.*)\\.html", "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }] },
    { "source": "/(.*)\\.svg",  "headers": [{ "key": "Content-Type", "value": "image/svg+xml" }] },
    { "source": "/(.*)\\.(jpg|jpeg)", "headers": [{ "key": "Content-Type", "value": "image/jpeg" }] }
  ]
}
